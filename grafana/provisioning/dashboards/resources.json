{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "title": "FactoryMind — Resources",
  "uid": "fm-resources",
  "version": 1,
  "timezone": "Europe/Rome",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["factorymind", "resources", "observability"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Node.js heap used / heap total (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "nodejs_heap_used_bytes{job=\"factorymind-backend\"} / 1024 / 1024", "legendFormat": "heap used", "refId": "A" },
        { "expr": "nodejs_heap_total_bytes{job=\"factorymind-backend\"} / 1024 / 1024", "legendFormat": "heap total", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Resident Set Size (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"factorymind-backend\"} / 1024 / 1024", "legendFormat": "RSS", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Event-loop lag P99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "nodejs_eventloop_lag_p99_seconds{job=\"factorymind-backend\"} * 1000", "legendFormat": "P99", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU load (1m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "node_load_1{job=\"factorymind-backend\"}", "legendFormat": "load1", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Mosquitto connections",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "mosquitto_connected_clients", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Postgres active connections",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"factorymind\"}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Influx points written (5m rate)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "fm-prometheus" },
      "targets": [
        { "expr": "sum(rate(factorymind_influx_points_written_total[5m]))", "refId": "A" }
      ]
    }
  ]
}
