# =============================================================================
# FactoryMind — example environment file.
#
# Copy to `.env` (the unattended `install.sh` does this automatically) and
# fill in the placeholders.  In production, every value containing "change_me",
# "please-generate", or any default below MUST be replaced with a strong
# secret — backend/src/config/index.js refuses to boot otherwise.
#
# Bilingual register (HANDOFF doctrine H-3): comments are EN; values that the
# customer-facing installer prints back in Italian are noted inline.
# =============================================================================

# ---- Application ----------------------------------------------------------
APP_ENV=development
APP_PORT=3002
LOG_LEVEL=info

# ---- PostgreSQL (metadata + RBAC + audit log) -----------------------------
POSTGRES_USER=factorymind
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=factorymind
DATABASE_URL=postgresql://factorymind:change_me_in_production@factorymind-postgres:5432/factorymind

# ---- InfluxDB 2.x (high-frequency time-series) ----------------------------
INFLUX_URL=http://factorymind-influxdb:8086
INFLUX_ORG=factorymind
INFLUX_BUCKET=factory-telemetry
INFLUX_TOKEN=please-generate-long-random-token-and-set-here
INFLUX_RETENTION_DAYS_RAW=30
INFLUX_RETENTION_DAYS_1M=365
INFLUX_RETENTION_DAYS_1H=1095

# Bootstrap-only credentials consumed by the influxdb image at first boot.
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change_me_influx_admin
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=please-generate-long-random-token-and-set-here

# ---- MQTT broker (Mosquitto) ----------------------------------------------
# Production: switch to mqtts://...:8883 and provide MQTT_PASSWORD.
MQTT_BROKER_URL=mqtt://factorymind-mosquitto:1883
MQTT_USERNAME=backend
MQTT_PASSWORD=
MQTT_CLIENT_ID=factorymind-backend
MQTT_KEEP_ALIVE=30
MQTT_RECONNECT_PERIOD=2000
MQTT_QOS_TELEMETRY=0
MQTT_QOS_ALARMS=1
MQTT_QOS_COMMANDS=2

# ---- Authentication / session / rate-limit --------------------------------
# JWT_SECRET MUST be ≥ 32 chars in production (config guardrail H-2).
JWT_SECRET=please-generate-at-least-32-character-secret-here
JWT_EXPIRES_IN=15m
JWT_ALGORITHM=HS256
JWT_REFRESH_TTL_HOURS=12
JWT_ACCESS_TTL=15m
CORS_ALLOWED_ORIGINS=http://localhost:5173
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=60
SESSION_IDLE_TIMEOUT_MIN=15
SESSION_ABSOLUTE_TIMEOUT_HR=12
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_CAP_SECONDS=900
PASSWORD_MIN_LENGTH=12
SPARKPLUG_ENABLED=false
HIBP_API_URL=https://api.pwnedpasswords.com/range
HIBP_DISABLED=false

# ---- OpenTelemetry --------------------------------------------------------
OTEL_SERVICE_NAME=factorymind-backend
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.05

# ---- OPC UA bridge (disabled by default; enable per tenant) ---------------
OPCUA_ENABLED=false
OPCUA_ENDPOINT=
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_SECURITY_MODE=SignAndEncrypt
OPCUA_USERNAME=
OPCUA_PASSWORD=
OPCUA_SAMPLING_INTERVAL_MS=1000
OPCUA_PUBLISHING_INTERVAL_MS=1000
# Comma-separated allow-list of OPC UA hostnames (R-OPCUA-VALIDATE-001).
# When OPCUA_ENABLED=true, the configured endpoint host MUST appear here.
OPCUA_ALLOWED_HOSTS=

# ---- Modbus bridge (disabled by default) ----------------------------------
MODBUS_ENABLED=false
MODBUS_TCP_HOST=
MODBUS_TCP_PORT=502
MODBUS_UNIT_ID=1
MODBUS_POLL_INTERVAL_MS=2000

# ---- Alerting / SMTP ------------------------------------------------------
ALERT_EVAL_INTERVAL_MS=5000
ALERT_ESCALATION_INTERVAL_MS=300000
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_FROM=
SMTP_URL=

# ---- Grafana --------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin
GRAFANA_URL=http://localhost:3000

# ---- Frontend (Vite) — VITE_* vars baked into the build at compile time --
VITE_API_BASE_URL=http://localhost:3002
VITE_WS_URL=ws://localhost:3002
VITE_MQTT_WS_URL=ws://localhost:9001
VITE_DEFAULT_FACILITY=mozzecane

# ---- Simulator ------------------------------------------------------------
SIM_FACILITY=mozzecane
SIM_LINES=2
SIM_MACHINES_PER_LINE=4
SIM_INTERVAL_MS=1000
SIM_FAULT_PROBABILITY=0.01

# ---- Admin bootstrap (install.sh appends FM_ADMIN_PASSWORD_HASH here) -----
FM_FACILITY_NAME=Stabilimento di Mozzecane
FM_ADMIN_EMAIL=
FM_ADMIN_PASSWORD_HASH=
FM_PUBLIC_BASE_URL=http://localhost
# Production guardrail: when true, backend refuses to boot if the seed
# admin would persist past first login (HANDOFF doctrine H-2).
FM_REQUIRE_CUSTOM_ADMIN=false

# ---- Housekeeping ---------------------------------------------------------
FM_HOUSEKEEPING_INTERVAL_HOURS=24
